@page "/record-transcribe"
@using ElBruno.HuggingFace
@using ElBruno.Whisper
@inject IJSRuntime JS
@implements IAsyncDisposable

<h2 class="mb-4"><i class="bi bi-mic text-success me-2"></i>Record &amp; Transcribe</h2>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card bg-dark text-light border-secondary">
            <div class="card-header border-secondary">
                <i class="bi bi-mic me-1"></i> Recording
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Whisper Model</label>
                    <select class="form-select bg-dark text-light border-secondary" @bind="selectedModelId"
                            disabled="@(isRecording || isProcessing)">
                        @foreach (var model in KnownWhisperModels.All)
                        {
                            <option value="@model.Id">@model.DisplayName (@model.Size)</option>
                        }
                    </select>
                </div>

                <div class="text-center py-4">
                    @if (isRecording)
                    {
                        <div class="recording-indicator mb-3">
                            <span class="recording-dot"></span>
                            <span class="ms-2 fw-bold text-danger">Recording...</span>
                        </div>
                        <p class="text-secondary">
                            <i class="bi bi-clock me-1"></i> @recordingDuration.ToString(@"mm\:ss")
                        </p>
                        <button class="btn btn-danger btn-lg" @onclick="StopRecording">
                            <i class="bi bi-stop-fill me-1"></i> Stop Recording
                        </button>
                    }
                    else if (hasRecording)
                    {
                        <div class="mb-3">
                            <i class="bi bi-check-circle text-success display-4"></i>
                            <p class="mt-2 text-secondary">Recording captured (@recordingDuration.ToString(@"mm\:ss"))</p>
                        </div>
                        <div class="d-flex gap-2 justify-content-center">
                            <button class="btn btn-success" @onclick="TranscribeRecording" disabled="@isProcessing">
                                @if (isProcessing)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                    <span>@progressMessage</span>
                                }
                                else
                                {
                                    <i class="bi bi-play-fill me-1"></i>
                                    <span>Transcribe</span>
                                }
                            </button>
                            <button class="btn btn-outline-secondary" @onclick="StartRecording" disabled="@isProcessing">
                                <i class="bi bi-arrow-repeat me-1"></i> Re-record
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <i class="bi bi-mic display-4 text-secondary"></i>
                            <p class="mt-2 text-secondary">Click to start recording from your microphone</p>
                        </div>
                        <button class="btn btn-success btn-lg" @onclick="StartRecording">
                            <i class="bi bi-mic-fill me-1"></i> Start Recording
                        </button>
                    }
                </div>

                @if (isProcessing && downloadPercent > 0)
                {
                    <div class="progress mt-3" style="height: 6px;">
                        <div class="progress-bar bg-success" style="width: @downloadPercent%"></div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card bg-dark text-light border-secondary h-100">
            <div class="card-header border-secondary">
                <i class="bi bi-card-text me-1"></i> Transcription Result
            </div>
            <div class="card-body">
                @if (errorMessage is not null)
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle me-1"></i> @errorMessage
                    </div>
                }
                else if (result is not null)
                {
                    <div class="mb-3">
                        <div class="d-flex gap-3 mb-3">
                            @if (result.DetectedLanguage is not null)
                            {
                                <span class="badge bg-secondary">
                                    <i class="bi bi-translate me-1"></i>@result.DetectedLanguage
                                </span>
                            }
                            <span class="badge bg-secondary">
                                <i class="bi bi-clock me-1"></i>@result.Duration.TotalSeconds.ToString("F1")s
                            </span>
                        </div>
                        <div class="transcript-box p-3 rounded">
                            @result.Text
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center text-secondary py-5">
                        <i class="bi bi-mic display-4"></i>
                        <p class="mt-3">Record audio, then click Transcribe to see results here.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string selectedModelId = KnownWhisperModels.WhisperTinyEn.Id;
    private bool isRecording;
    private bool hasRecording;
    private bool isProcessing;
    private TimeSpan recordingDuration;
    private string progressMessage = "Initializing...";
    private double downloadPercent;
    private TranscriptionResult? result;
    private string? errorMessage;
    private byte[]? recordedAudioData;
    private DotNetObjectReference<RecordTranscribe>? dotNetRef;
    private System.Timers.Timer? durationTimer;
    private DateTime recordingStartTime;

    private async Task StartRecording()
    {
        result = null;
        errorMessage = null;
        hasRecording = false;
        recordedAudioData = null;
        recordingDuration = TimeSpan.Zero;

        try
        {
            dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("audioRecorder.initialize");
            await JS.InvokeVoidAsync("audioRecorder.startRecording", dotNetRef);
            isRecording = true;
            recordingStartTime = DateTime.UtcNow;

            durationTimer = new System.Timers.Timer(500);
            durationTimer.Elapsed += (_, _) =>
            {
                recordingDuration = DateTime.UtcNow - recordingStartTime;
                InvokeAsync(StateHasChanged);
            };
            durationTimer.Start();
        }
        catch (Exception ex)
        {
            errorMessage = $"Could not start recording: {ex.Message}";
        }
    }

    private async Task StopRecording()
    {
        durationTimer?.Stop();
        durationTimer?.Dispose();
        durationTimer = null;

        try
        {
            await JS.InvokeVoidAsync("audioRecorder.stopRecording");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error stopping recording: {ex.Message}";
            isRecording = false;
        }
    }

    [JSInvokable]
    public void OnRecordingComplete(byte[] audioData)
    {
        recordedAudioData = audioData;
        isRecording = false;
        hasRecording = true;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnRecordingError(string error)
    {
        isRecording = false;
        errorMessage = error;
        InvokeAsync(StateHasChanged);
    }

    private async Task TranscribeRecording()
    {
        if (recordedAudioData is null || recordedAudioData.Length == 0) return;

        isProcessing = true;
        result = null;
        errorMessage = null;
        downloadPercent = 0;
        progressMessage = "Initializing...";

        try
        {
            var model = KnownWhisperModels.FindById(selectedModelId) ?? KnownWhisperModels.WhisperTinyEn;
            var tempPath = Path.Combine(Path.GetTempPath(), $"blazor_whisper_{Guid.NewGuid():N}.wav");

            try
            {
                await File.WriteAllBytesAsync(tempPath, recordedAudioData);

                var progress = new Progress<DownloadProgress>(p =>
                {
                    progressMessage = p.Stage switch
                    {
                        DownloadStage.Checking => "Checking model...",
                        DownloadStage.Downloading => $"Downloading model... {p.PercentComplete:F0}%",
                        DownloadStage.Validating => "Validating model...",
                        DownloadStage.Complete => "Transcribing...",
                        _ => p.Message ?? "Processing..."
                    };
                    downloadPercent = p.PercentComplete;
                    InvokeAsync(StateHasChanged);
                });

                progressMessage = "Loading model...";
                StateHasChanged();

                using var client = await WhisperClient.CreateAsync(
                    new WhisperOptions { Model = model },
                    progress: progress);

                progressMessage = "Transcribing audio...";
                StateHasChanged();

                result = await client.TranscribeAsync(tempPath);
            }
            finally
            {
                if (File.Exists(tempPath))
                    File.Delete(tempPath);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
            downloadPercent = 0;
        }
    }

    public async ValueTask DisposeAsync()
    {
        durationTimer?.Stop();
        durationTimer?.Dispose();

        if (isRecording)
        {
            try
            {
                await JS.InvokeVoidAsync("audioRecorder.stopRecording");
            }
            catch
            {
                // Component disposing, ignore JS errors
            }
        }

        dotNetRef?.Dispose();
    }
}
