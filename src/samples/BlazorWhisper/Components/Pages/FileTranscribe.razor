@page "/file-transcribe"
@using ElBruno.HuggingFace
@using ElBruno.Whisper
@inject IJSRuntime JS
@implements IDisposable

<h2 class="mb-4"><i class="bi bi-file-earmark-music text-info me-2"></i>File Upload &amp; Transcribe</h2>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card bg-dark text-light border-secondary">
            <div class="card-header border-secondary">
                <i class="bi bi-gear me-1"></i> Settings
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Whisper Model</label>
                    <select class="form-select bg-dark text-light border-secondary" @bind="selectedModelId" disabled="@isProcessing">
                        @foreach (var model in KnownWhisperModels.All)
                        {
                            <option value="@model.Id">@model.DisplayName (@model.Size)</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">WAV Audio File</label>
                    <InputFile class="form-control bg-dark text-light border-secondary"
                               OnChange="OnFileSelected"
                               accept=".wav"
                               disabled="@isProcessing" />
                    @if (selectedFile is not null)
                    {
                        <small class="text-secondary mt-1 d-block">
                            <i class="bi bi-file-earmark me-1"></i>@selectedFile.Name (@FormatSize(selectedFile.Size))
                        </small>
                    }
                </div>

                <button class="btn btn-info w-100" @onclick="Transcribe" disabled="@(selectedFile is null || isProcessing)">
                    @if (isProcessing)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>@progressMessage</span>
                    }
                    else
                    {
                        <i class="bi bi-play-fill me-1"></i>
                        <span>Transcribe</span>
                    }
                </button>

                @if (isProcessing && downloadPercent > 0)
                {
                    <div class="progress mt-3" style="height: 6px;">
                        <div class="progress-bar bg-info" style="width: @downloadPercent%"></div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card bg-dark text-light border-secondary h-100">
            <div class="card-header border-secondary">
                <i class="bi bi-card-text me-1"></i> Transcription Result
            </div>
            <div class="card-body">
                @if (errorMessage is not null)
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle me-1"></i> @errorMessage
                    </div>
                }
                else if (result is not null)
                {
                    <div class="mb-3">
                        <div class="d-flex gap-3 mb-3">
                            @if (result.DetectedLanguage is not null)
                            {
                                <span class="badge bg-secondary">
                                    <i class="bi bi-translate me-1"></i>@result.DetectedLanguage
                                </span>
                            }
                            <span class="badge bg-secondary">
                                <i class="bi bi-clock me-1"></i>@result.Duration.TotalSeconds.ToString("F1")s
                            </span>
                        </div>
                        <div class="transcript-box p-3 rounded">
                            @result.Text
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center text-secondary py-5">
                        <i class="bi bi-upload display-4"></i>
                        <p class="mt-3">Upload a WAV file and click Transcribe to see results here.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string selectedModelId = KnownWhisperModels.WhisperTinyEn.Id;
    private IBrowserFile? selectedFile;
    private bool isProcessing;
    private string progressMessage = "Initializing...";
    private double downloadPercent;
    private TranscriptionResult? result;
    private string? errorMessage;
    private CancellationTokenSource? cts;

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        result = null;
        errorMessage = null;
    }

    private async Task Transcribe()
    {
        if (selectedFile is null) return;

        isProcessing = true;
        result = null;
        errorMessage = null;
        downloadPercent = 0;
        progressMessage = "Initializing...";
        cts = new CancellationTokenSource();

        try
        {
            var model = KnownWhisperModels.FindById(selectedModelId) ?? KnownWhisperModels.WhisperTinyEn;

            var tempPath = Path.Combine(Path.GetTempPath(), $"blazor_whisper_{Guid.NewGuid():N}.wav");

            try
            {
                await using (var fs = new FileStream(tempPath, FileMode.Create))
                {
                    await selectedFile.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024)
                        .CopyToAsync(fs, cts.Token);
                }

                var progress = new Progress<DownloadProgress>(p =>
                {
                    progressMessage = p.Stage switch
                    {
                        DownloadStage.Checking => "Checking model...",
                        DownloadStage.Downloading => $"Downloading model... {p.PercentComplete:F0}%",
                        DownloadStage.Validating => "Validating model...",
                        DownloadStage.Complete => "Transcribing...",
                        _ => p.Message ?? "Processing..."
                    };
                    downloadPercent = p.PercentComplete;
                    InvokeAsync(StateHasChanged);
                });

                progressMessage = "Loading model...";
                StateHasChanged();

                using var client = await WhisperClient.CreateAsync(
                    new WhisperOptions { Model = model },
                    progress: progress,
                    cancellationToken: cts.Token);

                progressMessage = "Transcribing audio...";
                StateHasChanged();

                result = await client.TranscribeAsync(tempPath, cts.Token);
            }
            finally
            {
                if (File.Exists(tempPath))
                    File.Delete(tempPath);
            }
        }
        catch (OperationCanceledException)
        {
            errorMessage = "Transcription was cancelled.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
            downloadPercent = 0;
            cts?.Dispose();
            cts = null;
        }
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    public void Dispose()
    {
        cts?.Cancel();
        cts?.Dispose();
    }
}
